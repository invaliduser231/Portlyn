FROM golang:1.26.3-alpine AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ARG TARGETOS
ARG TARGETARCH
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build -o /app/nodeagent ./cmd/nodeagent

FROM alpine:3.20

WORKDIR /app

RUN apk add --no-cache ca-certificates tzdata && \
    addgroup -S app && \
    adduser -S app -G app && \
    mkdir -p /data && \
    chown -R app:app /app /data

COPY --from=builder /app/nodeagent /app/nodeagent

USER app

ENV XDG_CONFIG_HOME=/data

ENTRYPOINT ["/app/nodeagent"]
