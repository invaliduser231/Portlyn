# Copy this file to `.env.docker` and set real production values.

JWT_SECRET=replace-with-a-random-32-plus-character-secret
JWT_ISSUER=portlyn
APP_VERSION=docker
LOG_LEVEL=info

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
VIEWER_EMAIL=viewer@example.com
VIEWER_PASSWORD=

FRONTEND_BASE_URL=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
NEXT_PUBLIC_API_BASE_URL=

PORTLYN_API_PORT=8080
PORTLYN_HTTP_PORT=80
PORTLYN_HTTPS_PORT=443
LOKI_PORT=3100
GRAFANA_PORT=3001

DATABASE_DRIVER=postgres
# Leave DATABASE_URL empty to use the bundled Docker PostgreSQL service.
# Set DATABASE_URL to point to an external PostgreSQL server when needed.
DATABASE_URL=
POSTGRES_DB=portlyn
POSTGRES_USER=portlyn
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password

TOKEN_TTL=24h
REFRESH_TOKEN_TTL=720h
AUTH_RATE_LIMIT_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW=10m
AUTH_CACHE_TTL=1m
CSRF_TOKEN_TTL=12h
REQUEST_BODY_LIMIT_BYTES=1048576
AUDIT_BUFFER_SIZE=4096
NODE_OFFLINE_AFTER=2m

REDIRECT_HTTP_TO_HTTPS=false
ACME_ENABLED=false
ACME_EMAIL=
ACME_CA_URL=
ACME_POLL_INTERVAL=1m

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-grafana-password

OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=
OIDC_ALLOWED_EMAIL_DOMAINS=
OIDC_ADMIN_ROLE_CLAIM_PATH=realm_access.roles
OIDC_ADMIN_ROLE_VALUE=
OIDC_PROVIDER_LABEL=SSO
OIDC_ALLOW_EMAIL_LINKING=false
OIDC_REQUIRE_VERIFIED_EMAIL=true

OTP_ENABLED=true
OTP_TOKEN_TTL=10m
OTP_REQUEST_LIMIT=5
OTP_REQUEST_WINDOW=15m
OTP_RESPONSE_INCLUDES_CODE=false
REQUIRE_MFA_FOR_ADMINS=false

ALLOW_INSECURE_DEV_MODE=false
